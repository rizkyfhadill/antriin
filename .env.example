# ===========================================
# DATABASE (Supabase)
# ===========================================
# Connection string dari Supabase Dashboard
# Format: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[HOST]:[PORT]/postgres
#
# Langkah mendapatkan:
# 1. Buka https://supabase.com
# 2. Login dan buka project Anda
# 3. Settings → Database → Connection String
# 4. Pilih "Nodejs" dan copy connection string

DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ===========================================
# AUTHENTICATION
# ===========================================
# JWT Secret Key (WAJIB: minimal 32 karakter, acak)
#
# Generate dengan:
# macOS/Linux: openssl rand -base64 32
# Windows: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Online: https://generate-secret.vercel.app/32

JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# ===========================================
# NEXT.JS
# ===========================================
# Environment (development/production)
NODE_ENV=development

# Base URL aplikasi (untuk production ganti dengan domain Anda)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# OPTIONAL: Supabase Storage (jika pakai)
# ===========================================
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
